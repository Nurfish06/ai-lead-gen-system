# LeadPulse System Configuration

# --- Database ---
DB_HOST=postgres
DB_PORT=5432
DB_USER=user
DB_PASSWORD=pass
DB_NAME=leads

# --- Backend API (Node.js) ---
PORT=3000
OPENAI_API_KEY=sk-xxxx... # Required for AI email generation
ENRICHMENT_API_KEY=xxxx... # Key for your chosen enrichment provider

# --- n8n Security ---
# This token should match what you put in the "Header Auth" credential in n8n
ENRICHMENT_WEBHOOK_AUTH_TOKEN=your_secure_header_token_here

# --- Monitoring & Notifications ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXX/YYYY/ZZZZ
ADMIN_EMAIL=admin@example.com

# --- n8n External URL ---
# Required for webhooks to be reachable
N8N_WEBHOOK_URL=http://localhost:5678/
