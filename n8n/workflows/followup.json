{
  "name": "Automated Follow-up Workflow (Compatible)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "hours": 12 }]
        }
      },
      "id": "schedule-followup",
      "name": "Run Every 12 Hours",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [100, 300],
      "typeVersion": 1
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT l.id, l.name, l.email, l.company, l.status, ol.followup_count, ol.replied FROM leads l JOIN outreach_logs ol ON l.id = ol.lead_id WHERE l.status = 'contacted' AND ol.replied = false AND ol.followup_count < 3 AND (ol.last_followup_at IS NULL OR ol.last_followup_at < NOW() - INTERVAL '2 days') ORDER BY ol.followup_count ASC;"
      },
      "id": "fetch-followup-leads",
      "name": "Fetch Leads",
      "type": "n8n-nodes-base.postgres",
      "position": [300, 300],
      "typeVersion": 1
    },
    {
      "parameters": {
        "jsCode": "const lead = $input.first().json;\nreturn {\n  lead_id: lead.id,\n  email: lead.email,\n  subject: 'Re: ' + lead.company,\n  body: 'Hi ' + lead.name + ', following up on my last email.',\n  count: (lead.followup_count || 0) + 1\n};"
      },
      "id": "generate-content",
      "name": "Generate Content",
      "type": "n8n-nodes-base.code",
      "position": [500, 300],
      "typeVersion": 1
    },
    {
      "parameters": {
        "amount": 2,
        "unit": "seconds"
      },
      "id": "Safety Delay",
      "name": "Safety Delay",
      "type": "n8n-nodes-base.wait",
      "position": [700, 300],
      "typeVersion": 1
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "send",
        "to": "={{$json.email}}",
        "subject": "={{$json.subject}}",
        "message": "={{$json.body}}",
        "options": {}
      },
      "id": "Send Gmail",
      "name": "Send Gmail",
      "type": "n8n-nodes-base.gmail",
      "position": [900, 300],
      "typeVersion": 1
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=UPDATE outreach_logs SET followup_count = {{$node[\"generate-content\"].json.count}}, last_followup_at = NOW() WHERE lead_id = {{$node[\"generate-content\"].json.lead_id}};"
      },
      "id": "Update Log",
      "name": "Update Log",
      "type": "n8n-nodes-base.postgres",
      "position": [1100, 300],
      "typeVersion": 1
    }
  ],
  "connections": {
    "schedule-followup": { "main": [[{ "node": "Fetch Leads", "type": "main", "index": 0 }]] },
    "Fetch Leads": { "main": [[{ "node": "generate-content", "type": "main", "index": 0 }]] },
    "generate-content": { "main": [[{ "node": "Safety Delay", "type": "main", "index": 0 }]] },
    "Safety Delay": { "main": [[{ "node": "Send Gmail", "type": "main", "index": 0 }]] },
    "Send Gmail": { "main": [[{ "node": "Update Log", "type": "main", "index": 0 }]] }
  }
}