{
  "name": "Lead Pipeline Master Orchestration (Compatible)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "minutes": 30 }]
        }
      },
      "id": "schedule-trigger",
      "name": "Run Every 30 Minutes",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [100, 300],
      "typeVersion": 1
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH claimed_leads AS (SELECT id FROM leads WHERE status = 'pending' ORDER BY created_at ASC LIMIT 50 FOR UPDATE SKIP LOCKED) UPDATE leads SET status = 'enriching' FROM claimed_leads WHERE leads.id = claimed_leads.id RETURNING leads.id, leads.name, leads.email;"
      },
      "id": "Claim Leads",
      "name": "Claim Leads",
      "type": "n8n-nodes-base.postgres",
      "position": [300, 300],
      "typeVersion": 1
    },
    {
      "parameters": {
        "amount": 1,
        "unit": "seconds"
      },
      "id": "Throttle Delay",
      "name": "Throttle Delay",
      "type": "n8n-nodes-base.wait",
      "position": [500, 300],
      "typeVersion": 1
    },
    {
      "parameters": {
        "workflowId": "enrichment-workflow-id",
        "options": {}
      },
      "id": "Execute Enrichment",
      "name": "Execute Enrichment",
      "type": "n8n-nodes-base.executeWorkflow",
      "position": [700, 300],
      "typeVersion": 1
    }
  ],
  "connections": {
    "schedule-trigger": { "main": [[{ "node": "Claim Leads", "type": "main", "index": 0 }]] },
    "Claim Leads": { "main": [[{ "node": "Throttle Delay", "type": "main", "index": 0 }]] },
    "Throttle Delay": { "main": [[{ "node": "Execute Enrichment", "type": "main", "index": 0 }]] }
  }
}