{
  "name": "AI Outreach Workflow (v1 Fixed)",
  "nodes": [
    {
      "parameters": {
        "rule": "interval",
        "interval": 15,
        "unit": "minutes"
      },
      "id": "Run Every 15 Minutes",
      "name": "Run Every 15 Minutes",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [100, 300],
      "typeVersion": 1.1
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT * FROM leads WHERE status = 'enriched' AND (last_outreach IS NULL OR last_outreach < NOW() - INTERVAL '3 days') LIMIT 10 FOR UPDATE SKIP LOCKED;"
      },
      "id": "Fetch Leads",
      "name": "Fetch Leads",
      "type": "n8n-nodes-base.postgres",
      "position": [300, 300],
      "typeVersion": 1
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=INSERT INTO outreach_logs (lead_id, email_subject, email_body, status) VALUES ({{$node[\"Fetch Leads\"].json.id}}, '{{$json.email_subject}}', '{{$json.generated_email}}', 'sent') RETURNING id;"
      },
      "id": "Log Outreach",
      "name": "Log Outreach",
      "type": "n8n-nodes-base.postgres",
      "position": [1500, 200],
      "typeVersion": 1
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=UPDATE leads SET status = 'contacted', last_outreach = NOW() WHERE id = {{$node[\"Fetch Leads\"].json.id}};"
      },
      "id": "Update Lead",
      "name": "Update Lead",
      "type": "n8n-nodes-base.postgres",
      "position": [1700, 200],
      "typeVersion": 1
    }
  ],
  "connections": {
    "Run Every 15 Minutes": { "main": [[{ "node": "Fetch Leads", "type": "main", "index": 0 }]] },
    "Fetch Leads": { "main": [[{ "node": "Log Outreach", "type": "main", "index": 0 }]] },
    "Log Outreach": { "main": [[{ "node": "Update Lead", "type": "main", "index": 0 }]] }
  }
}