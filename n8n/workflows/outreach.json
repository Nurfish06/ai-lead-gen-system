{
  "name": "AI Outreach Workflow",
  "nodes": [
    {
      "parameters": {
        "rule": "interval",
        "interval": 15,
        "unit": "minutes"
      },
      "id": "Run Every 15 Minutes",
      "name": "Run Every 15 Minutes",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [100, 300],
      "typeVersion": 1.1
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT * FROM leads WHERE status = 'enriched' AND (last_outreach IS NULL OR last_outreach < NOW() - INTERVAL '3 days') LIMIT 10 FOR UPDATE SKIP LOCKED;",
        "options": {}
      },
      "id": "Fetch Ready Leads",
      "name": "Fetch Ready Leads",
      "type": "n8n-nodes-base.postgres",
      "position": [300, 300],
      "typeVersion": 1
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT status FROM service_health WHERE service_name = 'ai_email_api';",
        "options": {}
      },
      "id": "Check AI Service Health",
      "name": "Check AI Service Health",
      "type": "n8n-nodes-base.postgres",
      "position": [500, 300],
      "typeVersion": 1
    },
    {
      "parameters": {
        "maxQueriesPerUnit": 5,
        "unit": "minutes"
      },
      "id": "ai-rate-limit",
      "name": "AI Rate Limit",
      "type": "n8n-nodes-base.rateLimit",
      "position": [700, 300],
      "typeVersion": 1
    },
    {
      "parameters": {
        "jsCode": "const versions = ['v1_direct', 'v2_storytelling'];\nconst chosen = versions[Math.floor(Math.random() * versions.length)];\nreturn { prompt_version: chosen };"
      },
      "id": "ab-version-selector",
      "name": "A/B Version Selector",
      "type": "n8n-nodes-base.code",
      "position": [800, 450],
      "typeVersion": 2
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:5678/webhook/ai-engine",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "task", "value": "generate_email" },
            { "name": "prompt", "value": "=Write a personalized cold email to {{$node[\"Fetch Ready Leads\"].json.name}} from {{$node[\"Fetch Ready Leads\"].json.company}} in the {{$node[\"Fetch Ready Leads\"].json.industry}} industry. Use version: {{$node[\"A/B Version Selector\"].json.prompt_version}}. Return JSON with 'email_subject' and 'generated_email'." }
          ]
        }
      },
      "id": "generate-ai-email",
      "name": "AI Engine: Generate",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1000, 300],
      "typeVersion": 4.1
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:5678/webhook/ai-engine",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "task", "value": "evaluate_quality" },
            { "name": "prompt", "value": "=Review this email: {{$json.generated_email}}. Lead context: {{$node[\"Fetch Ready Leads\"].json}}. Score quality 0-10. Return JSON with 'quality_score' and 'reason'." }
          ]
        }
      },
      "id": "ai-quality-gate",
      "name": "AI Engine: Quality Gate",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1200, 300],
      "typeVersion": 4.1
    },
    {
      "parameters": {
        "conditions": {
          "number": [
            {
              "value1": "={{$json.quality_score}}",
              "operation": "largerEqual",
              "value2": 8
            }
          ]
        }
      },
      "id": "is-quality-high",
      "name": "Is Quality High? (>=8)",
      "type": "n8n-nodes-base.if",
      "position": [1400, 300],
      "typeVersion": 1
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE leads SET status = 'review_needed', updated_at = NOW() WHERE id = :leadId;",
        "queryParameters": "leadId={{$node[\"Fetch Ready Leads\"].json.id}}",
        "options": {}
      },
      "id": "set-review-needed",
      "name": "Set Status: Review Needed",
      "type": "n8n-nodes-base.postgres",
      "position": [1400, 500],
      "typeVersion": 1
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO outreach_logs (lead_id, email_subject, email_body, status, prompt_version) VALUES (:leadId, :subject, :body, 'pending', :version) RETURNING id;",
        "queryParameters": "leadId={{$node[\"Fetch Ready Leads\"].json.id}}, subject={{$node[\"AI Engine: Generate\"].json.email_subject}}, body={{$node[\"AI Engine: Generate\"].json.generated_email}}, version={{$node[\"A/B Version Selector\"].json.prompt_version}}",
        "options": {}
      },
      "id": "log-pending",
      "name": "Log-First: Pending",
      "type": "n8n-nodes-base.postgres",
      "position": [1600, 200],
      "typeVersion": 1
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT status FROM service_health WHERE service_name = 'gmail';",
        "options": {}
      },
      "id": "check-gmail-health",
      "name": "Check Gmail Health",
      "type": "n8n-nodes-base.postgres",
      "position": [1800, 200],
      "typeVersion": 1
    },
    {
      "parameters": {
        "maxQueriesPerUnit": 10,
        "unit": "minutes"
      },
      "id": "gmail-rate-limit",
      "name": "Gmail Rate Limit",
      "type": "n8n-nodes-base.rateLimit",
      "position": [2000, 200],
      "typeVersion": 1
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "send",
        "to": "={{$node[\"Fetch Ready Leads\"].json.email}}",
        "subject": "={{$node[\"AI Engine: Generate\"].json.email_subject}}",
        "message": "={{$node[\"AI Engine: Generate\"].json.generated_email}}",
        "options": {}
      },
      "id": "send-via-gmail",
      "name": "Send via Gmail",
      "type": "n8n-nodes-base.gmail",
      "position": [2200, 200],
      "typeVersion": 1
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE outreach_logs SET status = 'sent', sent_at = NOW(), thread_id = :threadId WHERE id = :logId;",
        "queryParameters": "logId={{$node[\"Log-First: Pending\"].json.id}}, threadId={{$node[\"Send via Gmail\"].json.threadId}}",
        "options": {}
      },
      "id": "update-log-sent",
      "name": "Update Log: Sent",
      "type": "n8n-nodes-base.postgres",
      "position": [2400, 200],
      "typeVersion": 1
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE leads SET status = 'contacted', last_outreach = NOW(), email_sent_count = email_sent_count + 1 WHERE id = :leadId;",
        "queryParameters": "leadId={{$node[\"Fetch Ready Leads\"].json.id}}",
        "options": {}
      },
      "id": "update-lead-status",
      "name": "Update Lead Status",
      "type": "n8n-nodes-base.postgres",
      "position": [2600, 200],
      "typeVersion": 1
    }
  ],
  "connections": {
    "Run Every 15 Minutes": { "main": [[{ "node": "Fetch Ready Leads", "type": "main", "index": 0 }]] },
    "Fetch Ready Leads": { "main": [[{ "node": "Check AI Service Health", "type": "main", "index": 0 }]] },
    "Check AI Service Health": { "main": [[{ "node": "AI Rate Limit", "type": "main", "index": 0 }]] },
    "AI Rate Limit": { "main": [[{ "node": "AB Version Selector", "type": "main", "index": 0 }]] },
    "AB Version Selector": { "main": [[{ "node": "AI Engine: Generate", "type": "main", "index": 0 }]] },
    "AI Engine: Generate": { "main": [[{ "node": "AI Engine: Quality Gate", "type": "main", "index": 0 }]] },
    "AI Engine: Quality Gate": { "main": [[{ "node": "Is Quality High? (>=8)", "type": "main", "index": 0 }]] },
    "Is Quality High? (>=8)": {
        "main": [[{ "node": "Log-First: Pending", "type": "main", "index": 0 }]],
        "false": [[{ "node": "Set Status: Review Needed", "type": "main", "index": 0 }]]
    },
    "Log-First: Pending": { "main": [[{ "node": "Check Gmail Health", "type": "main", "index": 0 }]] },
    "Check Gmail Health": { "main": [[{ "node": "Gmail Rate Limit", "type": "main", "index": 0 }]] },
    "Gmail Rate Limit": { "main": [[{ "node": "Send via Gmail", "type": "main", "index": 0 }]] },
    "Send via Gmail": { "main": [[{ "node": "Update Log: Sent", "type": "main", "index": 0 }]] },
    "Update Log: Sent": { "main": [[{ "node": "Update Lead Status", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" }
}