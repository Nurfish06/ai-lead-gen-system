{
  "name": "Service Health Monitor (Full & Robust)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "report-failure",
        "options": {}
      },
      "id": "report-failure-webhook",
      "name": "Report Failure Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        100,
        200
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=INSERT INTO service_health (service_name, failure_count, last_failure, last_checked, status) \nVALUES ('{{$json.body.service_name}}', 1, NOW(), NOW(), 'up')\nON CONFLICT (service_name) DO UPDATE \nSET failure_count = service_health.failure_count + 1, \n    last_failure = EXCLUDED.last_failure, \n    last_checked = EXCLUDED.last_checked\nRETURNING *;"
      },
      "id": "upsert-failure",
      "name": "Upsert Failure",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 1,
      "position": [
        300,
        200
      ],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "conditions": {
          "number": [
            {
              "value1": "={{$json.failure_count || 0}}",
              "operation": "largerEqual",
              "value2": 5
            }
          ]
        }
      },
      "id": "check-threshold",
      "name": "Threshold Reached?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        500,
        200
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=UPDATE service_health SET status = 'down' WHERE service_name = '{{$json.service_name}}';"
      },
      "id": "set-down",
      "name": "Set Service DOWN",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 1,
      "position": [
        700,
        150
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:5678/webhook/alert-manager",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "severity",
              "value": "critical"
            },
            {
              "name": "title",
              "value": "=Service DOWN: {{$node[\"upsert-failure\"].json.service_name}}"
            },
            {
              "name": "message",
              "value": "=The service has reached the failure threshold."
            },
            {
              "name": "workflow_name",
              "value": "Health Monitor"
            }
          ]
        }
      },
      "id": "alert-down",
      "name": "Alert Down",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [
        900,
        150
      ]
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "minutes": 15
            }
          ]
        }
      },
      "id": "recovery-trigger",
      "name": "Recovery Check Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [
        100,
        450
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT * FROM service_health WHERE status = 'down';"
      },
      "id": "fetch-down",
      "name": "Fetch DOWN Services",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 1,
      "position": [
        300,
        450
      ],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{!!$json.service_name}}",
              "value2": true
            }
          ]
        }
      },
      "id": "any-down?",
      "name": "Any Services Down?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        500,
        450
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=http://{{$json.service_name == 'enrichment_api' ? 'backend:3000/health' : 'ollama:11434/'}}",
        "options": {}
      },
      "id": "probe-service",
      "name": "Probe Service",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [
        700,
        450
      ],
      "onError": "continue"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=UPDATE service_health SET status = 'up', failure_count = 0, last_checked = NOW() WHERE service_name = '{{$node[\"fetch-down\"].json.service_name}}';"
      },
      "id": "set-up",
      "name": "Reset to UP",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 1,
      "position": [
        900,
        450
      ]
    }
  ],
  "connections": {
    "report-failure-webhook": {
      "main": [
        [
          {
            "node": "upsert-failure",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "upsert-failure": {
      "main": [
        [
          {
            "node": "check-threshold",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "check-threshold": {
      "main": [
        [
          {
            "node": "set-down",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "set-down": {
      "main": [
        [
          {
            "node": "alert-down",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "recovery-trigger": {
      "main": [
        [
          {
            "node": "fetch-down",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "fetch-down": {
      "main": [
        [
          {
            "node": "any-down?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "any-down?": {
      "main": [
        [
          {
            "node": "probe-service",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "probe-service": {
      "main": [
        [
          {
            "node": "set-up",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}