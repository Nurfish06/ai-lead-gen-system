{
  "name": "Real-Time Gmail Reply Handler (Compatible)",
  "nodes": [
    {
      "parameters": {
        "filters": {
          "q": "is:unread"
        },
        "options": {
          "downloadAttachments": false
        }
      },
      "id": "gmail-trigger",
      "name": "Gmail Reply Trigger",
      "type": "n8n-nodes-base.gmailTrigger",
      "typeVersion": 1,
      "position": [100, 300]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=SELECT l.id, l.email FROM leads l JOIN outreach_logs ol ON l.id = ol.lead_id WHERE l.email = '{{$json.from.email}}' OR ol.thread_id = '{{$json.threadId}}' LIMIT 1;"
      },
      "id": "find-lead",
      "name": "Find Associated Lead",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 1,
      "position": [300, 300]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{$json.id ? true : false}}",
              "value2": true
            }
          ]
        }
      },
      "id": "is-known-lead",
      "name": "Is Known Lead?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [500, 300]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=UPDATE leads SET status = 'responded', updated_at = NOW() WHERE id = {{$node[\"find-lead\"].json.id}};"
      },
      "id": "update-lead-responded",
      "name": "Update State: Responded",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 1,
      "position": [700, 200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:5678/webhook/alert-manager",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "severity", "value": "info" },
            { "name": "title", "value": "Lead Responded!" },
            { "name": "message", "value": "=Lead {{$node[\"find-lead\"].json.email}} has replied." }
          ]
        }
      },
      "id": "alert-response",
      "name": "Notify Sales Team",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [900, 200]
    }
  ],
  "connections": {
    "gmail-trigger": { "main": [[{ "node": "find-lead", "type": "main", "index": 0 }]] },
    "find-lead": { "main": [[{ "node": "is-known-lead", "type": "main", "index": 0 }]] },
    "is-known-lead": { "main": [[{ "node": "update-lead-responded", "type": "main", "index": 0 }]] },
    "update-lead-responded": { "main": [[{ "node": "alert-response", "type": "main", "index": 0 }]] }
  }
}
