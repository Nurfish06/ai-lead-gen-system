{
  "name": "Alert Manager (Compatible)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "alert-manager",
        "options": {}
      },
      "id": "alert-webhook",
      "name": "Alert Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=INSERT INTO pipeline_alerts (severity, title, message, workflow_name) VALUES ('{{$json.body.severity}}', '{{$json.body.title}}', '{{$json.body.message}}', '{{$json.body.workflow_name}}');"
      },
      "id": "log-alert-db",
      "name": "Log Alert to DB",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 1,
      "position": [450, 300]
    }
  ],
  "connections": {
    "Alert Webhook": { "main": [[{ "node": "Log Alert to DB", "type": "main", "index": 0 }]] }
  }
}