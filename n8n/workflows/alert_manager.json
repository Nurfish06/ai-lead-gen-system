{
  "name": "Full Alert Manager (Telegram & Gmail)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "alert-manager",
        "options": {}
      },
      "id": "alert-webhook",
      "name": "Alert Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [100, 300]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=INSERT INTO pipeline_alerts (severity, title, message, workflow_name) VALUES ('{{$json.body.severity}}', '{{$json.body.title}}', '{{$json.body.message}}', '{{$json.body.workflow_name}}') RETURNING *;"
      },
      "id": "log-to-db",
      "name": "Log to Database",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 1,
      "position": [300, 300]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{$json.severity}}",
              "value2": "critical"
            }
          ]
        }
      },
      "id": "is-critical?",
      "name": "Is Critical?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [500, 300]
    },
    {
      "parameters": {
        "chatId": "YOUR_CHAT_ID",
        "text": "=🚨 CRITICAL ALERT: {{$json.title}}\n\nMessage: {{$json.message}}\nSource: {{$json.workflow_name}}",
        "additionalFields": {}
      },
      "id": "send-telegram",
      "name": "Send Telegram",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [750, 200],
      "notes": "Replace YOUR_CHAT_ID with your actual Telegram Chat ID."
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "send",
        "to": "admin@example.com",
        "subject": "=⚠️ Pipeline Warning: {{$json.title}}",
        "message": "={{$json.message}}\n\nWorkflow: {{$json.workflow_name}}\nSeverity: {{$json.severity}}",
        "options": {}
      },
      "id": "send-email",
      "name": "Send Gmail",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 1,
      "position": [750, 400]
    }
  ],
  "connections": {
    "alert-webhook": { "main": [[{ "node": "log-to-db", "type": "main", "index": 0 }]] },
    "log-to-db": { "main": [[{ "node": "is-critical?", "type": "main", "index": 0 }]] },
    "is-critical?": { 
      "main": [
        [{ "node": "send-telegram", "type": "main", "index": 0 }],
        [{ "node": "send-email", "type": "main", "index": 0 }]
      ]
    }
  }
}