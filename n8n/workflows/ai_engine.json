{
  "name": "AI Engine (Universal Compatible)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "ai-engine",
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "position": [100, 300],
      "typeVersion": 1
    },
    {
      "parameters": {
        "values": {
          "string": [
            {
              "name": "provider",
              "value": "ollama"
            },
            {
              "name": "model",
              "value": "dengcao/Qwen3-8B:Q5_K_M"
            }
          ]
        },
        "options": {}
      },
      "id": "resolve-settings",
      "name": "Resolve Settings",
      "type": "n8n-nodes-base.set",
      "position": [300, 300],
      "typeVersion": 1
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{$json.provider}}",
              "value2": "ollama"
            }
          ]
        }
      },
      "id": "is-ollama?",
      "name": "Is Ollama?",
      "type": "n8n-nodes-base.if",
      "position": [500, 300],
      "typeVersion": 1
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://ollama:11434/api/generate",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "model", "value": "={{$json.model}}" },
            { "name": "prompt", "value": "={{$node[\"Webhook Trigger\"].json.body.prompt}}" },
            { "name": "stream", "value": false }
          ]
        }
      },
      "id": "call-ollama",
      "name": "Call Ollama",
      "type": "n8n-nodes-base.httpRequest",
      "position": [700, 200],
      "typeVersion": 3
    },
    {
      "parameters": {
        "jsCode": "return {\n  generated_text: $input.first().json.response,\n  provider: 'ollama'\n};"
      },
      "id": "parse-ollama",
      "name": "Parse Ollama",
      "type": "n8n-nodes-base.code",
      "position": [900, 200],
      "typeVersion": 1
    }
  ],
  "connections": {
    "webhook-trigger": { "main": [[{ "node": "resolve-settings", "type": "main", "index": 0 }]] },
    "resolve-settings": { "main": [[{ "node": "is-ollama?", "type": "main", "index": 0 }]] },
    "is-ollama?": { "main": [[{ "node": "call-ollama", "type": "main", "index": 0 }]] },
    "call-ollama": { "main": [[{ "node": "parse-ollama", "type": "main", "index": 0 }]] }
  }
}
